# Bunny — environment variables (example)
#
# The server reads the process environment (it does not auto-load `.env`).
# Typical workflow:
#   cp .env.example .env
#   # edit .env with real values
#   set -a && source .env && set +a
#   cargo run -p bunny-server -- start
#
# Persistent config can also live in:
#   ~/.config/bunny/config.yaml   (see BunnyConfig in crates/bunny-core/src/config.rs)
# CLI flags on `bunny start` / `bunny dev` override bind host and port.
#
# Never commit `.env`, `secrets.enc`, or `bunny.db`.

# -----------------------------------------------------------------------------
# Secrets vault
# -----------------------------------------------------------------------------
# Unlock ~/.config/bunny/secrets.enc on startup (optional if you use `bunny secrets unlock`).
# BUNNY_SECRETS_PASSPHRASE=change-me

# App secrets belong in the vault, not here:
#   bunny secrets set OPENAI_API_KEY --scope system
# PTY children receive them as BUNNY_SECRET_OPENAI_API_KEY (allowlisted only).

# -----------------------------------------------------------------------------
# Server (Figment: BUNNY_<SECTION>_<KEY>, nested keys joined with _)
# -----------------------------------------------------------------------------
# BUNNY_SERVER_BIND_HOST=127.0.0.1
# BUNNY_SERVER_PORT=7681
# BUNNY_SERVER_DATA_DIR=~/.config/bunny

# -----------------------------------------------------------------------------
# Auth & security
# -----------------------------------------------------------------------------
# BUNNY_AUTH_MODE=local
# BUNNY_AUTH_RELAY_URL=
# BUNNY_AUTH_REQUIRE_AUTH=true
# BUNNY_SECURITY_DEFAULT_ROLE=viewer
# BUNNY_SECURITY_SESSION_TTL_MINUTES=120
# BUNNY_SECURITY_EXPOSE_CDP=false
# BUNNY_SECURITY_EXPOSE_VNC=false
# MFA TOTP secrets at rest (32-byte hex or base64; optional — else ~/.config/bunny/mfa.key)
# BUNNY_MFA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Mobile push (FCM legacy HTTP API)
# -----------------------------------------------------------------------------
# Accepted by the server directly or via config push.fcm_server_key:
# BUNNY_FCM_SERVER_KEY=
# BUNNY_PUSH_FCM_SERVER_KEY=
# BUNNY_PUSH_ENABLED=true

# -----------------------------------------------------------------------------
# WebRTC sidecar (also configurable in config.yaml under `webrtc:`)
# -----------------------------------------------------------------------------
# BUNNY_WEBRTC_ENABLED=true
# BUNNY_WEBRTC_SIDECAR_PORT=18782
# Comma-separated STUN URLs (passed to the Node sidecar):
# BUNNY_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
# Optional TURN (required for some mobile/NAT setups):
# BUNNY_WEBRTC_TURN_URL=
# BUNNY_WEBRTC_TURN_USERNAME=
# BUNNY_WEBRTC_TURN_CREDENTIAL=

# -----------------------------------------------------------------------------
# Team chats (also configurable in config.yaml under `team_chats:`)
# -----------------------------------------------------------------------------
# BUNNY_TEAM_CHATS__LINK_CODE_TTL_MINUTES=15

# -----------------------------------------------------------------------------
# Agents (also configurable in config.yaml under `agents:`)
# -----------------------------------------------------------------------------
# BUNNY_AGENTS__MAX_TURNS=30

# -----------------------------------------------------------------------------
# Discord (also configurable in config.yaml under `discord:`)
# -----------------------------------------------------------------------------
# BUNNY_DISCORD_ENABLED=true

# -----------------------------------------------------------------------------
# Terminal & browser (optional overrides)
# -----------------------------------------------------------------------------
# BUNNY_TERMINAL_SHELL=/bin/bash
# BUNNY_TERMINAL_BACKEND=tmux
# BUNNY_BROWSER_ENABLED=true
# BUNNY_BROWSER_WIDTH=1440
# BUNNY_BROWSER_HEIGHT=900

# -----------------------------------------------------------------------------
# Logging (tracing-subscriber / `tracing` crate)
# -----------------------------------------------------------------------------
# RUST_LOG=bunny=info,tower_http=warn,hyper=warn

# -----------------------------------------------------------------------------
# Internal — set by the agent for sidecars; do not set manually unless debugging
# -----------------------------------------------------------------------------
# BUNNY_WEBRTC_PORT=
# BUNNY_STUN_URLS=
# BUNNY_TURN_URL=
# BUNNY_TURN_USERNAME=
# BUNNY_TURN_CREDENTIAL=
# BUNNY_CDP_URL=
# BUNNY_CDP_PORT=
# BUNNY_SESSION_ID=
# BUNNY_BROWSER_ID=
